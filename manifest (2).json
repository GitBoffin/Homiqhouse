{
  "id": "homiqhouse-ondo-state",
  "name": "HomiqHouse",
  "short_name": "HomiqHouse",
  "description": "Find houses, jobs and buy & sell across Ondo State. No agent fees, no hidden charges.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "orientation": "portrait",
  "background_color": "#1A1A1A",
  "theme_color": "#B8935A",
  "lang": "en",
  "dir": "ltr",
  "categories": ["lifestyle", "shopping", "business"],
  "prefer_related_applications": false,
  "icons": [
    {
      "src": "/apple-touch-icon.png",
      "sizes": "180x180",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/favicon-96x96.png",
      "sizes": "96x96",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/web-app-manifest-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/web-app-manifest-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "scope_extensions": [
    { "origin": "https://homiq.online" },
    { "origin": "https://www.homiq.online" }
  ],
  "launch_handler": {
    "client_mode": ["focus-existing", "auto"]
  },
  "share_target": {
    "action": "/",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+homiq",
      "url": "/?url=%s"
    }
  ],
  "shortcuts": [
    {
      "name": "Browse Houses",
      "short_name": "Houses",
      "description": "Find houses across Ondo State",
      "url": "/?page=houses",
      "icons": [{ "src": "/web-app-manifest-192x192.png", "sizes": "192x192" }]
    },
    {
      "name": "Find Jobs",
      "short_name": "Jobs",
      "description": "Find your next job in Ondo State",
      "url": "/?page=jobs",
      "icons": [{ "src": "/web-app-manifest-192x192.png", "sizes": "192x192" }]
    },
    {
      "name": "Buy & Sell",
      "short_name": "Marketplace",
      "description": "Buy and sell items near you",
      "url": "/?page=buysell",
      "icons": [{ "src": "/web-app-manifest-192x192.png", "sizes": "192x192" }]
    }
  ]
}
